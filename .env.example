# ── solutis-sync ──────────────────────────────────────────────────

# MySQL (read/write)
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=solutis

# SQL Server 17 (TOTVS – read-only)
MSSQL_DSN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=127.0.0.1;DATABASE=totvs;UID=sa;PWD=sa

# Scheduler
SYNC_CRON_HOUR='3'
SYNC_CRON_MINUTE=0
SYNC_CRON_WEEK=""

# App
APP_NAME=solutis-sync
LOG_LEVEL=INFO
